# =============================================================================
# LiquidityManager — env template
# =============================================================================
# Copy to .env and fill values. .env is gitignored. Never commit secrets.

# ----------------------------------------------------------------------------
# Network
# ----------------------------------------------------------------------------
# CDPM and Cetus DLMM packages are only deployed on mainnet today.
SUI_NETWORK=mainnet
# Optional gRPC override; falls back to Mysten public endpoint.
SUI_GRPC_URL=

# ----------------------------------------------------------------------------
# Pool selection
# ----------------------------------------------------------------------------
# Template ships only sui-usdc. Add new files under src/pools/ + register in
# src/pools/index.ts to introduce new pairs.
POOL_PROFILE=sui-usdc
# Required: the on-chain Cetus DLMM pool object id for SUI/USDC.
SUI_USDC_POOL_ID=

# ----------------------------------------------------------------------------
# Agent role key (REQUIRED — at least ONE of these two)
# ----------------------------------------------------------------------------
# Option A: explicit bech32 private key (preferred for prod with HSM/keystore)
AGENT_PRIVATE_KEY=
# Option B: BIP-39 mnemonic; runtime derives at AGENT_DERIVATION_PATH
AGENT_MNEMONICS=
# Path applied when deriving from mnemonic. Default is "Sui Wallet account 1"
# (note: NOT the wallet's default — account index 1, not 0).
AGENT_DERIVATION_PATH=m/44'/784'/1'/0'/0'
# Strongly recommended: fail to start if derived address doesn't match.
EXPECTED_AGENT_ADDRESS=

# ----------------------------------------------------------------------------
# Treasury role (optional — TREASURY_ENABLED=true to turn on the layer)
# ----------------------------------------------------------------------------
# IMPORTANT: use a DIFFERENT mnemonic than AGENT_MNEMONICS — agent compromise
# must not leak treasury funds. Reread CLAUDE.md §"Multi-role keys".
TREASURY_ENABLED=false
# Option A: explicit bech32 private key
TREASURY_PRIVATE_KEY=
# Option B: BIP-39 mnemonic (per-user deposit addresses derive from this)
TREASURY_MNEMONICS=
TREASURY_MASTER_DERIVATION_PATH=m/44'/784'/0'/0'/0'
# Per-user deposit addresses derive at TREASURY_USER_BASE_PATH/{index}' (index ≥ 1).
TREASURY_USER_BASE_PATH=m/44'/784'/0'/0'
EXPECTED_TREASURY_MASTER_ADDRESS=
# Watcher poll interval (ms) for inbound deposit detection.
TREASURY_WATCHER_INTERVAL_MS=15000
# Cost formula: cost_credits = base + volume_usdc_atomic × fee_rate.
# Defaults: 0.10 USDC base + 0.1% volume. Tune per market.
TREASURY_REBALANCE_BASE_COST=10
TREASURY_REBALANCE_FEE_RATE=0.0000001
# When true, PMs whose owner isn't registered get skipped entirely.
# Default false: dev/test convenience — unregistered PMs rebalance for free.
TREASURY_REQUIRE_REGISTRATION=false

# ----------------------------------------------------------------------------
# Strategy + execution mode
# ----------------------------------------------------------------------------
STRATEGY=multiBinSpot                   # singleBin | multiBinSpot
# When true, rebalancer submits one atomic unified PTB per tick instead of
# 5 separate transactions. Default false until mainnet-validated.
UNIFIED_TX=false

# ----------------------------------------------------------------------------
# Lending (Scallop + Kai)
# ----------------------------------------------------------------------------
LENDING_ENABLED=true
LENDING_SCALLOP_ENABLED=true
LENDING_KAI_ENABLED=true
LENDING_APY_CACHE_TTL_MS=60000

# ----------------------------------------------------------------------------
# Storage + loop tuning
# ----------------------------------------------------------------------------
DB_FILE=./data/app.db
EVENT_POLL_INTERVAL_MS=5000
REBALANCE_INTERVAL_MS=60000
PER_PM_COOLDOWN_MS=30000

# ----------------------------------------------------------------------------
# Price feed
# ----------------------------------------------------------------------------
PRICE_FEED=onchain                       # onchain | (future: pyth / binance)
