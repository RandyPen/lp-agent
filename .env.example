# =============================================================================
# LiquidityManager — env template
# =============================================================================
# Copy to .env and fill values. .env is gitignored. Never commit secrets.

# ----------------------------------------------------------------------------
# Network
# ----------------------------------------------------------------------------
# CDPM and Cetus DLMM packages are only deployed on mainnet today.
SUI_NETWORK=mainnet
# Optional gRPC override; falls back to Mysten public endpoint.
SUI_GRPC_URL=

# ----------------------------------------------------------------------------
# Pool selection
# ----------------------------------------------------------------------------
# Template ships only sui-usdc. Add new files under src/pools/ + register in
# src/pools/index.ts to introduce new pairs.
POOL_PROFILE=sui-usdc
# Required: the on-chain Cetus DLMM pool object id for SUI/USDC.
#
# How to find it:
#   1. Go to the Cetus app (app.cetus.zone) → DLMM tab → find the SUI/USDC pool.
#   2. Click the pool to open its detail page. The object ID appears in the page
#      URL or in the "Pool Info" section. It must start with "0x".
#   3. Alternatively: open Sui Explorer (suiscan.xyz or suiexplorer.com), search
#      for the pool, and copy the Object ID from the object page.
#
# IMPORTANT:
#   - Must be a DLMM pool object ID, NOT a CLMM pool. The two protocols have
#     different object types; the agent will fail if given a CLMM ID.
#   - Must match the configured SUI_NETWORK (mainnet vs testnet).
#   - If left empty the agent aborts at startup with a clear config error.
#   - Do NOT paste a placeholder — the agent validates the value is non-empty.
#
# Verified mainnet Cetus DLMM SUI/USDC pool (as of 2026-06-12):
#   0x64e590b0e4d4f7dfc7ae9fae8e9983cd80ad83b658d8499bf550a9d4f6667076
#   (USDC/SUI, binStep=50, baseFeeRate=0.4%; object type
#   0x5664f9d3…::pool::Pool<…usdc::USDC, 0x2::sui::SUI>; bin-price cross-checked
#   against Binance SUIUSDC within <1%. Re-verify before use — operator opts in.)
SUI_USDC_POOL_ID=

# ----------------------------------------------------------------------------
# Agent role key (REQUIRED — at least ONE of these two)
# ----------------------------------------------------------------------------
# Option A: explicit bech32 private key (preferred for prod with HSM/keystore)
AGENT_PRIVATE_KEY=
# Option B: BIP-39 mnemonic; runtime derives at AGENT_DERIVATION_PATH
AGENT_MNEMONICS=
# Path applied when deriving from mnemonic. Default is "Sui Wallet account 1"
# (note: NOT the wallet's default — account index 1, not 0).
AGENT_DERIVATION_PATH=m/44'/784'/1'/0'/0'
# REQUIRED: fail to start if derived address doesn't match. Must be a
# 0x-prefixed 64-hex Sui address. (Run scripts/verify-agent-address.ts to
# find the address for your mnemonic before pasting it here.)
EXPECTED_AGENT_ADDRESS=
# Optional override of the TOFU identity file path. Default sits next to
# DB_FILE as `<dbDir>/agent.identity.json`. The file is written on first run
# and verified against the derived address on every subsequent run; mismatch
# aborts startup. Delete the file to rotate keys intentionally.
AGENT_IDENTITY_FILE=

# ----------------------------------------------------------------------------
# Treasury role (optional — TREASURY_ENABLED=true to turn on the layer)
# ----------------------------------------------------------------------------
# IMPORTANT: use a DIFFERENT mnemonic than AGENT_MNEMONICS — agent compromise
# must not leak treasury funds. Reread CLAUDE.md §"Multi-role keys".
TREASURY_ENABLED=false
# Option A: explicit bech32 private key
TREASURY_PRIVATE_KEY=
# Option B: BIP-39 mnemonic (per-user deposit addresses derive from this)
TREASURY_MNEMONICS=
TREASURY_MASTER_DERIVATION_PATH=m/44'/784'/0'/0'/0'
# Per-user deposit addresses derive at TREASURY_USER_BASE_PATH/{index}' (index ≥ 1).
TREASURY_USER_BASE_PATH=m/44'/784'/0'/0'
EXPECTED_TREASURY_MASTER_ADDRESS=
# Optional override of the treasury TOFU identity file path.
TREASURY_IDENTITY_FILE=
# Watcher poll interval (ms) for inbound deposit detection.
TREASURY_WATCHER_INTERVAL_MS=15000
# Cost formula: cost_credits = base + volume_usdc_atomic × fee_rate.
# Defaults: 0.10 USDC base + 0.1% volume. Tune per market.
TREASURY_REBALANCE_BASE_COST=10
TREASURY_REBALANCE_FEE_RATE=0.0000001
# When true, PMs whose owner isn't registered get skipped entirely.
# Default false: dev/test convenience — unregistered PMs rebalance for free.
TREASURY_REQUIRE_REGISTRATION=false

# HTTP API (v2 — expose treasury endpoints to client apps)
# Default: disabled. Set true to start the API alongside the watcher.
# Host: bind-local by default (127.0.0.1). Exposing beyond localhost requires
# a reverse proxy + TLS — never expose the raw HTTP API to the public internet.
TREASURY_HTTP_ENABLED=false
TREASURY_HTTP_HOST=127.0.0.1
# Port 8378 (8377 is the ML prediction sidecar; 8378 is the treasury API)
TREASURY_HTTP_PORT=8378

# ----------------------------------------------------------------------------
# Strategy + execution mode
# ----------------------------------------------------------------------------
STRATEGY=multiBinSpot                   # singleBin | multiBinSpot | emaTrend | mlAgent
# When true (the DEFAULT), the rebalancer submits one atomic unified PTB per
# tick. Set false for the legacy 5-transaction sequence — that path is
# NON-ATOMIC (a failed add after a successful remove leaves the position
# closed with capital idling until the next tick).
# UNIFIED_TX=true

# Safety margin (bps) on dryRun-estimated remove proceeds before they are
# counted into the re-add amounts (unified path). Undershoot is safe.
# READD_PROCEEDS_HAIRCUT_BPS=10

# Max active-bin drift (bins) between plan time and execution. Checked
# client-side right before submit AND asserted on-chain (see below).
# SLIPPAGE_MAX_BIN_DRIFT=1
# Append the DLMM router's validate_active_id_slippage assertion to add PTBs.
# SLIPPAGE_GUARD_ONCHAIN=true
# DLMM router published_at providing utils::validate_active_id_slippage.
# Defaults to the verified mainnet address; override on testnet/devnet.
# DLMM_PUBLISHED_AT=0x36d7c12e8497cee9259dd6b0da9f8bbe955134d658a1e3e7c682d43c7a955125

# Idempotent retry on transient RPC errors: extra resubmits of the IDENTICAL
# signed bytes (Sui dedupes by digest; a rebuilt tx could double-execute).
# RPC_RETRY_ATTEMPTS=1
# RPC_RETRY_BACKOFF_MS=2000

# Churn cap: max NON-emergency rebalances per PM per rolling hour (all
# rebalances rows count, incl. failed). EXTREME withdrawals are exempt.
# Checked before the treasury charge, so capped ticks never debit users.
# REBALANCE_MAX_PER_HOUR=4

# ----------------------------------------------------------------------------
# Lending (Scallop + Kai)
# ----------------------------------------------------------------------------
LENDING_ENABLED=true
LENDING_SCALLOP_ENABLED=true
LENDING_KAI_ENABLED=true
LENDING_APY_CACHE_TTL_MS=60000

# ----------------------------------------------------------------------------
# Seal (encrypted research-report sharing — placeholders for v2)
# ----------------------------------------------------------------------------
# Per-user model: each user's treasury deposit address (m/44'/784'/0'/0'/N')
# doubles as their Seal authorised-reader identity. User pays through a
# Move contract that mints a Subscription / Allowlist entry to their own
# deposit address; treasury runtime then derives that user's keypair and
# signs the SessionKey on their behalf. Agent keypair does NOT participate.
# See docs/seal-integration.md.
#
# SEAL_ENABLED=false
# SEAL_PACKAGE_ID=                       # Move package that hosts seal_approve*
# SEAL_KEY_SERVER_URLS=                  # comma-separated, e.g. "https://ks.a.io,https://ks.b.io"
# SEAL_THRESHOLD=2                       # t-of-n for the key-server set
# SEAL_SESSION_TTL_MIN=30                # SessionKey TTL minutes

# ----------------------------------------------------------------------------
# Identity files (TOFU) — applies to BOTH agent and treasury roles
# ----------------------------------------------------------------------------
# Set true to disable the TOFU layer entirely (tests / ephemeral dev loops).
# Default: persistence is on, identity files live next to DB_FILE.
IDENTITY_FILES_DISABLED=false

# ----------------------------------------------------------------------------
# Storage + loop tuning
# ----------------------------------------------------------------------------
DB_FILE=./data/app.db
EVENT_POLL_INTERVAL_MS=5000
REBALANCE_INTERVAL_MS=60000
PER_PM_COOLDOWN_MS=30000

# ----------------------------------------------------------------------------
# Price feed
# ----------------------------------------------------------------------------
PRICE_FEED=onchain                       # onchain | binance | (future: pyth)
# Only consumed when PRICE_FEED=binance. Symbol must be a valid Binance spot
# pair. Default SUIUSDC; falls back to SUIUSDT if your region doesn't list USDC.
BINANCE_SYMBOL=SUIUSDC
# Optional override for restricted regions (default api.binance.com).
BINANCE_BASE_URL=

# ----------------------------------------------------------------------------
# ML prediction sidecar (v1 — Python FastAPI process; see docs/prediction-service-design.md)
# ----------------------------------------------------------------------------
# Base URL of the local Python inference sidecar. Change port if 8377 is taken.
# The sidecar listens on 127.0.0.1 only (never exposes to network).
PREDICTION_SIDECAR_URL=http://127.0.0.1:8377
# HTTP request timeout for /predict calls (ms). After this, mlAgent falls back
# to Tier 0 (emaTrend) and records fallback="timeout" in the predictions table.
PREDICTION_TIMEOUT_MS=2000

# ----------------------------------------------------------------------------
# ML runtime switches
# ----------------------------------------------------------------------------
# When true, mlAgent records predictions and state-machine transitions but does
# NOT submit any on-chain PTBs. The active STRATEGY continues to execute.
# Run shadow mode for ≥14 days before enabling live inference (W7 gate).
ML_SHADOW_MODE=false

# Strategy used as Tier 0 fallback when mlAgent cannot use the prediction
# provider (sidecar down, PSI drift, feature missing, timeout).
# Must be one of: singleBin | multiBinSpot | emaTrend
FALLBACK_STRATEGY=emaTrend

# ----------------------------------------------------------------------------
# Risk thresholds (L1 soft circuit / L2 EXTREME / L3 emergency stop)
# See docs/risk-monitoring-design.md for parameter semantics.
# ----------------------------------------------------------------------------
# L2: 5-minute price volatility threshold — enter EXTREME if exceeded (fraction, e.g. 0.10 = 10%)
RISK_EXTREME_VOLATILITY_5M=0.10
# L2: 5-minute TVL drop threshold — enter EXTREME if TVL falls by this fraction (e.g. 0.50 = 50%)
RISK_TVL_DROP_5M=0.50
# L2: cross-market spread threshold (Cetus vs Binance). Enter EXTREME if sustained above this.
RISK_SPREAD_EXTREME=0.05
# L2: how long (ms) the spread must stay above RISK_SPREAD_EXTREME before entering EXTREME.
RISK_SPREAD_SUSTAIN_MS=30000
# L2: if pAbove + pBelow exceeds this, enter EXTREME (high break-out probability).
RISK_P_BREAK_SUM=0.7
# L2: 24-hour PnL threshold (fraction of NAV). Negative value: e.g. -0.05 = -5%.
RISK_PNL_24H_PCT=-0.05
# L1: soft circuit-breaker lower spread bound — increase lending %, narrow half-width.
RISK_L1_SPREAD_SOFT_BAND_LOW=0.005
# L1: soft circuit-breaker upper spread bound (above this is L2 territory).
RISK_L1_SPREAD_SOFT_BAND_HIGH=0.01
# L2 exit hysteresis: 5-min volatility must recede below this before EXTREME
# can exit. MUST be strictly below RISK_EXTREME_VOLATILITY_5M (validated).
# RISK_VOLATILITY_RECOVERY=0.07
# L2 per-source staleness thresholds (ms) — a single dead feed trips EXTREME
# even while the other feeds keep the aggregate snapshot timestamp fresh.
# RISK_SOURCE_STALE_SUI_MS=60000
# RISK_SOURCE_STALE_CETUS_MS=180000
# RISK_SOURCE_STALE_DERIV_MS=600000
# How often the background riskObserver loop samples market data to feed the
# risk monitor's rolling windows. Default 30_000 (30 s). Lower values give
# finer resolution for 5-minute volatility / TVL-drop / spread circuits but
# increase CPU and RPC load.
# RISK_OBSERVER_INTERVAL_MS=30000

# ----------------------------------------------------------------------------
# L3 emergency-stop trip conditions. Once tripped, all on-chain operations
# halt until the operator runs scripts/risk-reset-emergency.ts and restarts.
# ----------------------------------------------------------------------------
# Trip when L2 EXTREME was entered this many times within the window.
# RISK_L3_REPEATED_L2_COUNT=3
# RISK_L3_REPEATED_L2_WINDOW_MS=3600000
# Trip when market data has been stale this long (ms) while a position is
# open. Must exceed RISK_SOURCE_STALE_SUI_MS (validated).
# RISK_L3_OUTAGE_MS=300000
# Trip when 24h PnL falls below this fraction (catastrophic loss). Must be
# more negative than RISK_PNL_24H_PCT (validated).
# RISK_L3_PNL_PCT=-0.15
# Trip after this many consecutive failed on-chain rebalance attempts.
# RISK_L3_TX_FAILURE_COUNT=5

# ----------------------------------------------------------------------------
# State-machine thresholds (STATE_*). Defaults are the v1 pre-calibration
# values; W5 grid-search results are deployed by setting these env vars —
# no code edit needed. Cross-field rules validated at load:
#   STATE_DRIFT_STRENGTH_EXIT < STATE_DRIFT_STRENGTH_ENTRY
#   STATE_P_BREAK_SUM_EXTREME_EXIT < STATE_P_BREAK_SUM_EXTREME
# ----------------------------------------------------------------------------
# STATE_K_W=2.0
# STATE_U_HIGH=0.8
# STATE_DRIFT_STRENGTH_ENTRY=2.0
# STATE_DRIFT_STRENGTH_EXIT=1.5
# STATE_P_BREAK_ENTRY=0.6
# STATE_P_BREAK_SUM_EXTREME=0.7
# STATE_P_BREAK_SUM_EXTREME_EXIT=0.6
# STATE_TREND_BIAS_STRONG=0.7
