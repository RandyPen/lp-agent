# --- Network ---
# CDPM and Cetus DLMM packages are only deployed on mainnet.
SUI_NETWORK=mainnet
# Optional override; falls back to Mysten public gRPC for the network.
SUI_GRPC_URL=

# --- Pool selection ---
# v0 ships only sui-usdc. To fork to a different asset, add src/pools/<name>.ts and set this.
POOL_PROFILE=sui-usdc

# --- Agent key ---
# Phase 0: agent's Sui Ed25519 private key (suiprivkey1...). Phase 1+ moves to encrypted file.
AGENT_PRIVATE_KEY=

# --- Storage ---
DB_FILE=./data/app.db

# --- Loop tuning ---
EVENT_POLL_INTERVAL_MS=5000
REBALANCE_INTERVAL_MS=60000
PER_PM_COOLDOWN_MS=30000

# --- Price feed ---
# v0: 'onchain' (aggregate Cetus pool swap events). P1+: 'pyth' | 'binance'.
PRICE_FEED=onchain

# --- Logging ---
LOG_LEVEL=info
